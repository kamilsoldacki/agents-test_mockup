# Local only (npm run dev). Production: set keys on Render (or sync via GitHub Actions secret).
# Never put XI_API_KEY* in VITE_* vars — they must not ship in the client bundle.
#
# Dual residency (UI Platform select / ?residency=eu|global):
#   XI_API_KEY_GLOBAL — https://api.elevenlabs.io (Global)
#   XI_API_KEY_EU     — https://api.eu.residency.elevenlabs.io (EU residency)
# Legacy: XI_API_KEY is accepted as a fallback for EU only (existing deploys).
XI_API_KEY_GLOBAL=
XI_API_KEY_EU=
# XI_API_KEY=  — legacy EU fallback if XI_API_KEY_EU is unset
# AGENT_ID=agent_7201ky2fs4xtfwg9tn2x641n318p — EU default (server)
# AGENT_ID_GLOBAL=agent_0101kp3evekhf25tpfv24b3kf37w — Global default (server)
# BRANCH_ID=agtbrch_4301ky2fs5b2f3rs50hn9sq987d7 — EU branch (server/token-server.mjs)
# BRANCH_ID_GLOBAL=agtbrch_5401kp3evewjfdzvg4pzgd3cxcse — Global branch
# BRANCH_ID=false — omit branch_id on token/agent-config for all regions
# TOKEN_SERVER_PORT=3456
# PORT= — set by Render/Railway/Fly in production

# VITE_BASE_PATH=/  — preview build under a path prefix
# VITE_API_BASE=https://agents-test-mockup.onrender.com — only if UI is hosted separately from the API

# VITE_DEV_USE_TOKEN_SERVER=false — local Vite without /api/token proxy

# Optional GitHub Pages (static-only) fallback:
# VITE_PAGES_FORCE_WEBRTC=true
# VITE_BRANCH_ID=agtbrch_4301ky2fs5b2f3rs50hn9sq987d7 — EU client branch override
# VITE_BRANCH_ID_GLOBAL=agtbrch_5401kp3evewjfdzvg4pzgd3cxcse — Global client branch
# VITE_BRANCH_ID=false — omit branch_id on token URL
# VITE_USE_WEBSOCKET=true / VITE_USE_AGENT_ID_ONLY=true — emergency modes

# Regional keys are required for live settings (no repo mock fallback):
#   GET  /api/agent-config  — live system prompt, first message, language, LLM, TTS, widget flags
#   POST /api/tts           — TTS QC regenerate+play with current UI voice settings
# Pass ?residency=eu|global (or body.residency for TTS) so the server uses the matching origin + key.
# Overrides never PATCH/PUT the agent — session-only via Conversation.startSession({ overrides }).
